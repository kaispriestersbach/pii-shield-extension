{
  "name": "pii-shield-tests",
  "version": "1.1.1",
  "private": true,
  "scripts": {
    "build": "node scripts/build-offscreen-runtime.mjs",
    "build:offscreen": "node scripts/build-offscreen-runtime.mjs",
    "stage:model": "node scripts/stage-model.mjs",
    "test": "playwright test",
    "test:unit": "node tests/replacement-engine.test.mjs && node tests/pii-detectors.test.mjs && node tests/masking-engine.test.mjs",
    "test:all": "npm run test:unit && npm run test",
    "serve:fixtures": "npx serve tests/fixtures -p 3000 --no-clipboard"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "serve": "^14.2.0"
  }
}
